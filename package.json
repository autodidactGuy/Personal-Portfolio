{
  "name": "personal-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf .next out",
    "dev": "yarn resume:generate && yarn search:generate && next dev",
    "dev:clean": "yarn clean && yarn resume:generate && yarn search:generate && next dev",
    "icons:generate": "node scripts/generate-content-icons.mjs",
    "resume:generate": "node scripts/generate-resume-json.mjs",
    "search:generate": "node scripts/generate-search-index.mjs",
    "seo:assets": "node scripts/generate-seo-assets.mjs",
    "seo:og": "node scripts/generate-og-images.mjs",
    "seo:generate": "yarn seo:assets && yarn seo:og",
    "build:site": "next build",
    "build": "yarn lint && yarn seo:assets && yarn resume:generate && yarn search:generate && yarn build:site",
    "start": "serve out",
    "lint": "biome check src cloudflare-worker/src",
    "lint:fix": "biome check --write src cloudflare-worker/src",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@heroui/react": "3.0.4",
    "@heroui/styles": "^3.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-spectrum/provider": "^3.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "19",
    "@types/react-dom": "19",
    "animate.css": "^4.1.1",
    "autoprefixer": "^10.4.17",
    "clsx": "^2",
    "gray-matter": "^4.0.3",
    "intl-messageformat": "^11.2.0",
    "next": "15",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.33",
    "react": "19",
    "react-calendly": "^4.3.0",
    "react-dom": "19",
    "react-hook-form": "^7.50.1",
    "react-icons": "^5.0.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "serve": "^14.2.6",
    "sharp": "^0.34.5"
  },
  "resolutions": {
    "**/postcss": "8.5.12"
  }
}
